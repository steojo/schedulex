# Post for Me API key — https://app.postforme.dev (use a project scoped to this app)
POST_FOR_ME_API_KEY=

# The connected X account id, from GET /v1/social-accounts
X_SOCIAL_ACCOUNT_ID=

# Password for the single-user login gate
APP_PASSWORD=

# HMAC key for the session cookie — generate with: openssl rand -hex 32
SESSION_SECRET=
